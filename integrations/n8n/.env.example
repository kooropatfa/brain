# n8n / meet-to-inbox — environment template. Copy to Railway service variables (NOT committed).
# Never commit real secrets; this file documents the shape only (field.yml secrets.method: env_example).

# ── n8n core (Railway) ─────────────────────────────────────────────────────
# Railway injects $PORT; tell n8n to use it. The public URL is your Railway domain.
N8N_PORT=${PORT}
N8N_PROTOCOL=https
N8N_HOST=your-service.up.railway.app
WEBHOOK_URL=https://your-service.up.railway.app/
GENERIC_TIMEZONE=UTC

# Lock down the n8n editor UI (it is exposed publicly on Railway). Basic auth on the editor;
# the webhook endpoint itself is protected by the shared secret below, not by this.
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me-strong

# Encryption key for stored credentials (the GitHub token). Set ONCE and keep stable, or n8n cannot
# decrypt saved credentials after a redeploy. Generate: openssl rand -hex 24
N8N_ENCRYPTION_KEY=set-a-stable-random-hex-key

# ── meet-to-inbox workflow ─────────────────────────────────────────────────
# Shared secret the Apps Script poller must present in the POST body ({ "secret": "..." }).
# Generate: openssl rand -hex 24 — and put the SAME value in the Apps Script poller config.
N8N_WEBHOOK_SECRET=set-a-stable-random-hex-secret

# Where the capture lands: your knowledge repo, as owner/name. This env var is the SOURCE OF TRUTH
# for the flow's target — the workflow does NOT parse your knowledge repo's brain.config.yml at
# runtime, so keep this value in agreement with it manually.
BRAIN_REPO=your-org/brain
BRAIN_BRANCH=main

# ── GitHub Contents-API credential ─────────────────────────────────────────
# NOT read from env by the workflow — it is stored as an n8n "Header Auth" credential named
# "GitHub token (Authorization: Bearer)" so n8n encrypts it. Documented here for completeness:
#   Header name:  Authorization
#   Header value: Bearer <TOKEN>
# Token = a fine-grained PAT (or GitHub App installation token) scoped to the Brain repo with
# Repository permissions → Contents: Read and write. Nothing else. See README "GitHub token".
# GITHUB_TOKEN=github_pat_xxx   (entered in the n8n credential UI, not as a plain env var)
